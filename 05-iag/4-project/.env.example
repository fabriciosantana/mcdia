# Docling / Hugging Face
HF_TOKEN=

# OpenAI for generation
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano

# RAG embedding configuration
# Use "ollama" for local/remote Ollama or "openai" for OpenAI embeddings
RAG_EMBEDDING_ENGINE=ollama
RAG_EMBEDDING_MODEL=qwen3-embedding:0.6b
RAG_EMBEDDING_BATCH_SIZE=32
RAG_OPENAI_API_BASE_URL=https://api.openai.com/v1
RAG_OPENAI_API_KEY=

# Retrieval tuning
RAG_TOP_K=30
RAG_TOP_K_RERANKER=5
CHUNK_SIZE=800
CHUNK_OVERLAP=150
ENABLE_RAG_HYBRID_SEARCH=true
ENABLE_RAG_HYBRID_SEARCH_ENRICHED_TEXTS=true

# Vector database target (local or cloud Chroma)
VECTOR_DB=chroma
CHROMA_HTTP_HOST=localhost
CHROMA_HTTP_PORT=8000
CHROMA_HTTP_SSL=false
CHROMA_TENANT=default_tenant
CHROMA_DATABASE=default_database
# Example:
# CHROMA_HTTP_HEADERS=X-Chroma-Token=<SEU_TOKEN>

# Ollama connector (local or hosted)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=
OLLAMA_KEEP_ALIVE=24h

# Open WebUI API settings used by the helper scripts
OPENWEBUI_URL=http://localhost:8080
OPENWEBUI_API_KEY=
OPENWEBUI_EVAL_MODEL=gpt-5-nano
# Optional. If omitted, the judge reuses OPENWEBUI_EVAL_MODEL.
OPENWEBUI_JUDGE_MODEL=

# Evaluation-time generation parameters used by scripts/run_rag_eval.py
# Leave empty to use the provider defaults.
RAG_EVAL_TEMPERATURE=
RAG_EVAL_TOP_P=
RAG_EVAL_MAX_TOKENS=
# Use only if the backend/model supports deterministic seeds.
RAG_EVAL_SEED=
